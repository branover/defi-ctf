{
  "id": "nft-marketplace-tutorial",
  "name": "Your First Flip",
  "description": "Meet the NFT Marketplace. A seller bot is unloading corgi NFTs cheap, and a buyer bot will pay a premium for anything above a certain rarity. Buy low, list high, and pocket the difference. A guided tutorial shows you how to navigate the marketplace UI.",
  "version": "1.0.0",
  "category": "tutorial",
  "difficulty": "beginner",
  "tags": [
    "tutorial",
    "nft",
    "nft-marketplace",
    "js-sdk",
    "flip"
  ],
  "chain": {
    "blockCount": 200,
    "blockIntervalMs": 600,
    "botSeed": 5,
    "blocksPerCandle": 10
  },
  "tokens": [
    {
      "symbol": "WETH",
      "decimals": 18,
      "type": "weth"
    }
  ],
  "pools": [],
