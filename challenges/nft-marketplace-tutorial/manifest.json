      "id": "collection",
      "type": "CTFCollection",
      "params": [
        "Tutorial Corgis",
        "CORGI",
        100
      ]
    },
    {
      "id": "marketplace",
      "type": "NFTMarketplace",
      "params": [
        "{{collection}}",
        "{{token:WETH}}"
      ]
    }
  ],
